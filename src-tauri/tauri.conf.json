{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ComputerAgent",
  "version": "0.1.0",
  "identifier": "local.computeragent.app",
  "build": {
    "beforeDevCommand": "npm --prefix frontend run dev",
    "beforeBuildCommand": "npm --prefix frontend run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "ComputerAgent",
        "width": 1440,
        "height": 960,
        "minWidth": 1200,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "shortDescription": "Offline-first desktop AI assistant",
    "longDescription": "ComputerAgent turns natural-language desktop tasks into structured, approved local workflows with audit logs and rollback support."
  }
}
